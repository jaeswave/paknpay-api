PORT=5000
MONGODB_URI=mongodb+srv://your-connection-string
JWT_SECRET=your-super-secret-jwt-key-change-thi
FRONTEND_URL=http://localhost:5173

# Leave PAYSTACK_SECRET_KEY blank (or set to sk_test_simulation) to run in
# TEST/SIMULATE MODE — the driver payment flow will use a local simulated
# checkout page instead of calling the real Paystack API, so you can test
# the full pay -> verify -> exit-countdown flow with zero Paystack account.
# Set a real key (sk_live_... or a real sk_test_... from your Paystack
# dashboard) to use real Paystack payments.
PAYSTACK_SECRET_KEY=

# Shared secret for the platform admin login (commission dashboard).
# Pick any strong string — this is separate from attendant/owner logins.
ADMIN_SECRET=change-this-to-something-only-you-know
